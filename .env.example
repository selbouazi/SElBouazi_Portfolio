# Elige UN proveedor de IA. El primero con key se usará:

# 1. Groq (GRATIS, sin tarjeta, modelos Llama 3)
#    Consigue key en: https://console.groq.com/keys
VITE_GROQ_API_KEY=

# 2. Google Gemini (GRATIS, requiere cuenta de facturación)
#    Consigue key en: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# 3. OpenAI (de pago)
#    Consigue key en: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# Formspree form ID para el formulario de contacto
# Crea un form gratis en: https://formspree.io
VITE_FORMSPREE_ID=
