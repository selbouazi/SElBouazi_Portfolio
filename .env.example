# API Key para el chat AI (server-side, NO prefijo VITE_)
# En Vercel: añadir como Environment Variable en el dashboard
# En local: no necesaria, el chat usa respuestas locales
GROQ_API_KEY=

# Opcional: para desarrollo local con IA real
# Usa VITE_GROQ_API_KEY si quieres pruebas locales directas
# VITE_GROQ_API_KEY=

# Formspree form ID (opcional)
# Crea un form gratis en: https://formspree.io
# VITE_FORMSPREE_ID=
